// Post Expand
// --------------------------------------------------
.posts-expand {
  &.index {
    .post-title, .post-meta {
      text-align: $site-meta-text-align;

      +mobile() {
        text-align: center;
      }
    }

    .post-meta {
      margin: 5px 0 20px 0;
    }

    .post-block:first-child {
      margin-top: -20px;
      padding-top: 0;
    }

    .post-eof {
      display: block;
    }
  }

  .post-block:not(:first-child) {
    margin-top: 0px;
  }

  .post-title, .post-meta {
    text-align: center;
  }

  .post-body img {
    margin-left: 0;
  }

  .post-tags {
    text-align: left;

    a {
      background: $whitesmoke;
      border-bottom: none;
      padding: 1px 5px;

      &:hover {
        background: $grey-light;
      }
    }
  }

  .post-nav {
    margin-top: 40px;
  }
}

.posts-expand .post-button {
  margin-top: 20px;
}

.post-button {
  margin-top: 20px;
  text-align: center;

  .btn {
    display: block;
    margin: 0 auto;
    // color: $grey-dim;
    background: none;
    border: 0;
    border-bottom: 2px solid var(--btn-default-border-color);
    padding: 0;
    transition-property: border;
    display: inline-block;

    &:hover {
      border-bottom-color: var(--btn-default-hover-border-color);
    }
  }
}
